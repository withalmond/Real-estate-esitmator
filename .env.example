# Supabase project URL. The NEXT_PUBLIC value is safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key. This key is public by design; keep row-level security enabled.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only credentials used by the /api/walkthroughs route.
# Never prefix this value with NEXT_PUBLIC_ and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: defaults to "room-images" if omitted.
SUPABASE_ROOM_IMAGES_BUCKET=room-images
